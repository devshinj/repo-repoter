# PostgreSQL
POSTGRES_PASSWORD=your-secure-password

# LLM (Qwen via vLLM)
QWEN_CODER_KEY=your-qwen-api-key
QWEN_MODEL=qwen3-coder-next
QWEN_API_URL=https://open-llm.cudo.co.kr:8877/vllm/v1

# HRMS OAuth
AUTH_HRMS_ID=your-hrms-client-id
AUTH_HRMS_SECRET=your-hrms-client-secret
AUTH_HRMS_ISSUER=https://your-hrms-issuer-url
# NextAuth
AUTH_SECRET=your-nextauth-secret
AUTH_URL=https://your-app-url

# Admin
ADMIN_PASSWORD=your-admin-password
